{
  "name": "next-sketch",
  "version": "0.3.1",
  "description": "p5.js-style canvas sketches for React/Next.js — headless hooks plus drop-in <CanvasSketch>/<ThreeSketch>/<P5Sketch>/<FiberSketch> components, SSR-safe and DPR-aware, with optional Three.js, p5.js, and react-three-fiber engines behind their own subpath exports and a shared WebGL context budget.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "require": "./dist/three.js",
      "default": "./dist/three.js"
    },
    "./p5": {
      "types": "./dist/p5.d.ts",
      "require": "./dist/p5.js",
      "default": "./dist/p5.js"
    },
    "./fiber": {
      "types": "./dist/fiber.d.ts",
      "require": "./dist/fiber.js",
      "default": "./dist/fiber.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "nextjs",
    "canvas",
    "sketch",
    "p5js",
    "animation",
    "simulation",
    "creative-coding",
    "three",
    "threejs",
    "webgl",
    "3d",
    "p5",
    "p5js",
    "react-three-fiber",
    "r3f",
    "game"
  ],
  "author": "ReinanBr",
  "license": "MIT",
  "homepage": "https://github.com/reinanbr/next-sketch#readme",
  "bugs": {
    "url": "https://github.com/reinanbr/next-sketch/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@p5-wrapper/react": ">=5.0.0",
    "@react-three/fiber": ">=8.0.0",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    },
    "@p5-wrapper/react": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    }
  },
  "devDependencies": {
    "@p5-wrapper/react": "^5.0.4",
    "@react-three/fiber": "^9.6.1",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "p5": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/reinanbr/next-sketch"
  }
}
